<!DOCTYPE glassfish-web-app PUBLIC
    "-//GlassFish.org//DTD GlassFish Application Server 3.1 Servlet 3.0//EN"
    "http://glassfish.org/dtds/glassfish-web-app_3_0-1.dtd">
<!--
  GlassFish / Payara deployment descriptor.
  delegate="false": load WEB-INF/lib classes (Spring, MyBatis, HSQLDB) before
  server-level classes, preventing GlassFish's own frameworks from shadowing the
  application's dependencies and interfering with Spring's class wiring.
-->
<glassfish-web-app>
  <class-loader delegate="false"/>
</glassfish-web-app>
